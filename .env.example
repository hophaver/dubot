DISCORD_BOT_TOKEN=TOKEN
TELEGRAM_BOT_TOKEN=TOKEN
# Optional: force startup platform (discord, telegram, or both).
# If unset and both tokens are set, start.sh runs both platforms simultaneously.
BOT_PLATFORM=
HA_URL=URL
HA_ACCESS_TOKEN=TOKEN
OLLAMA_URL=URL

# /himas: Home Assistant Assist (POST /api/conversation/process) runs first when enabled.
HIMAS_ASSIST_ENABLED=true
# BCP-47 language for Assist (e.g. en, fi)
HIMAS_ASSIST_LANGUAGE=en
# Optional: Assist agent_id from HA (e.g. conversation.home_assistant or your pipeline agent)
HIMAS_ASSIST_AGENT_ID=

# When Assist cannot handle the request, the bot falls back to pattern matching + LLM JSON parse.
# HIMAS_PARSE_PROVIDER: auto (use user's /model cloud vs local), ollama, or openrouter
HIMAS_PARSE_PROVIDER=auto
# Fixed model for fallback parse (Ollama name, or OpenRouter id like openai/gpt-4o-mini if provider/openrouter or auto with a slash)
HIMAS_PARSE_MODEL=

# OpenRouter API key (used for cloud models, cloud chat, and usually /bal):
OPENROUTER_API_KEY=
# Optional advanced overrides (normally leave empty):
OPENROUTER_CHAT_API_KEY=
OPENROUTER_MANAGEMENT_API_KEY=

# Cursor user key for /cursor checks (preferred variable name).
# Note: Cursor's spend endpoint may still require Admin API permissions.
CURSOR_USER_API_KEY=
# Backward-compatible alias:
CURSOR_API_KEY=

# Site update script (scripts/site-update-1.py): SSH host, user, remote dir and script names
SITE_UPDATE_HOST=IP
SITE_UPDATE_USER=USER
SITE_UPDATE_DIRECTORY=~/DIRECTORY
SITE_UPDATE_SCRIPT=stop.sh
SITE_UPDATE_SCRIPT_PREVIEW=preview.sh
# Password for SSH (used with sshpass when set; leave empty for key-based auth)
SITE_UPDATE_SSH_PASSWORD=PASSWORD
