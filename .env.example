DISCORD_BOT_TOKEN=TOKEN
TELEGRAM_BOT_TOKEN=TOKEN
# Optional: force startup platform (discord, telegram, or both).
# If unset and both tokens are set, start.sh runs both platforms simultaneously.
BOT_PLATFORM=
HA_URL=URL
HA_ACCESS_TOKEN=TOKEN
OLLAMA_URL=URL

# OpenRouter keys. Optional.
# Chat/completions key (used for cloud models and cloud chat):
OPENROUTER_CHAT_API_KEY=
# Management key (used for /bal credits endpoint):
OPENROUTER_MANAGEMENT_API_KEY=
# Backward-compatible single key variable (used for both if dedicated keys are not set):
OPENROUTER_API_KEY=

# Cursor user key for /cursor checks (preferred variable name).
# Note: Cursor's spend endpoint may still require Admin API permissions.
CURSOR_USER_API_KEY=
# Backward-compatible alias:
CURSOR_API_KEY=

# Site update script (scripts/site-update-1.py): SSH host, user, remote dir and script names
SITE_UPDATE_HOST=IP
SITE_UPDATE_USER=USER
SITE_UPDATE_DIRECTORY=~/DIRECTORY
SITE_UPDATE_SCRIPT=stop.sh
SITE_UPDATE_SCRIPT_PREVIEW=preview.sh
# Password for SSH (used with sshpass when set; leave empty for key-based auth)
SITE_UPDATE_SSH_PASSWORD=PASSWORD
